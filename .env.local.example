# Supabase project URL (found in the Supabase dashboard > Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=

# Supabase anon/publishable key (safe to expose to the client)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role key (server only, never ship to the client)
SUPABASE_SERVICE_ROLE_KEY=

# Stripe secret key (server only)
STRIPE_SECRET_KEY=

# Stripe webhook signing secret (verify webhook payloads with this)
STRIPE_WEBHOOK_SECRET=

# Stripe publishable key (client-safe)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Resend API key (server only)
RESEND_API_KEY=

# From address for all transactional email
RESEND_FROM_EMAIL=noreply@ignite27.co.uk

# Reply-to for transactional email (customer replies land in Tom's inbox)
RESEND_REPLY_TO_EMAIL=tom@lincolnshiremarketing.co.uk

# In non-prod, only send email to allowlisted addresses
EMAIL_ALLOWLIST_ENABLED=true

# Base URL used for magic links, Stripe redirects, and canonical URLs
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Environment name (local | prod)
NEXT_PUBLIC_ENVIRONMENT=local
